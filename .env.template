# Gemini API Key (Obtain from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# TTS Engine type: "EDGE" (High quality neural server voice) or "BROWSER" (Local browser voice)
TTS_TYPE=EDGE

# Voice code for Edge TTS (e.g. es-MX-DaliaNeural, ja-JP-NanamiNeural, en-GB-LibbyNeural, zh-CN-XiaoxiaoNeural, es-PY-TaniaNeural)
EDGE_VOICE=zh-CN-XiaoxiaoNeural